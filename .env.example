# ─────────────────────────────────────────────────────────────────────────────
# Caregiver Platform — environment variables
# Copy to `.env` for local dev. In production, set these in your host's dashboard
# (never commit real secrets — .env is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend (server) ────────────────────────────────────────────────────────

# MongoDB Atlas connection string (Atlas is required for $vectorSearch).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/?retryWrites=true&w=majority

# Port the API listens on. Most container hosts inject PORT automatically.
PORT=5000

# Google Gemini API key (chat responses). https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Groq API key (chat history compaction). Optional — chat still works without it.
# https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Comma-separated list of allowed browser origins for CORS in production, e.g.
#   CORS_ORIGINS=https://your-app.vercel.app,https://www.yourdomain.com
# Leave unset locally to allow all origins.
CORS_ORIGINS=

# Set to "production" on your backend host to suppress verbose prompt/response logs.
NODE_ENV=development

# ── Frontend (Vite, build-time) ─────────────────────────────────────────────

# Base URL of the deployed backend API. Inlined into the client bundle at build
# time (public — no secrets). Unset locally -> defaults to http://localhost:5000.
#   VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=
